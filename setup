#!/bin/bash
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SKILL_INSTALL_DIR="$HOME/.claude/skills"

echo ""
echo "linear-sdlc — SDLC workflow for Linear + Claude Code"
echo "====================================================="
echo ""

# 1. Check dependencies
echo "Checking dependencies..."
command -v node >/dev/null || { echo "Error: node is required (brew install node)"; exit 1; }
command -v gh >/dev/null || { echo "Error: gh CLI is required (brew install gh)"; exit 1; }
command -v git >/dev/null || { echo "Error: git is required"; exit 1; }
echo "  node $(node --version)"
echo "  gh $(gh --version | head -1)"
echo "  git $(git --version)"
echo ""

# 2. Detect existing Linear API key (supports rotating/updating the key)
SETTINGS="$HOME/.claude/settings.json"
mkdir -p "$(dirname "$SETTINGS")"

EXISTING_KEY=""
if [ -f "$SETTINGS" ]; then
  EXISTING_KEY=$(SETTINGS_PATH="$SETTINGS" node -e "
    try {
      const s = JSON.parse(require('fs').readFileSync(process.env.SETTINGS_PATH, 'utf8'));
      const k = s && s.mcpServers && s.mcpServers.linear && s.mcpServers.linear.env && s.mcpServers.linear.env.LINEAR_API_KEY;
      if (typeof k === 'string' && k && !k.includes('YOUR_LINEAR_API_KEY')) process.stdout.write(k);
    } catch {}
  ")
fi

# Env var always wins (non-interactive installs / CI)
if [ -n "${LINEAR_API_KEY:-}" ]; then
  :
elif [ -n "$EXISTING_KEY" ]; then
  MASKED="***${EXISTING_KEY: -4}"
  echo "A Linear API key is already configured ($MASKED)."
  printf "Replace it? [y/N] "
  read -r REPLY
  echo ""
  if [ "$REPLY" = "y" ] || [ "$REPLY" = "Y" ]; then
    printf "Enter new Linear API key: "
    read -r LINEAR_API_KEY
    echo ""
  else
    LINEAR_API_KEY="$EXISTING_KEY"
    echo "  Keeping existing key."
  fi
else
  echo "Enter your Linear API key (from Linear Settings → API → Personal API keys):"
  read -r LINEAR_API_KEY
  echo ""
fi

if [ -z "$LINEAR_API_KEY" ]; then
  echo "Error: LINEAR_API_KEY is required"
  exit 1
fi

# 3. Configure MCP server in ~/.claude/settings.json
# Pass the key via env var so special characters in the key cannot break JS string literals
echo "Configuring Linear MCP server..."
LINEAR_API_KEY="$LINEAR_API_KEY" SETTINGS_PATH="$SETTINGS" node -e "
  const fs = require('fs');
  const file = process.env.SETTINGS_PATH;
  let s = {};
  try { s = JSON.parse(fs.readFileSync(file, 'utf8')); } catch {}
  s.mcpServers = s.mcpServers || {};
  s.mcpServers.linear = {
    type: 'npm',
    package: '@anthropic-ai/linear-mcp-server',
    env: { LINEAR_API_KEY: process.env.LINEAR_API_KEY }
  };
  fs.writeFileSync(file, JSON.stringify(s, null, 2) + '\n');
"

# 3b. Restrict permissions on settings.json — it contains the Linear API key in
# plaintext. Best-effort: any failure is silently ignored so we never block the
# install on a filesystem that doesn't support POSIX permissions or NTFS ACLs.
#
# POSIX (macOS, Linux, WSL on a Linux-native filesystem): chmod 600 is enough.
chmod 600 "$SETTINGS" 2>/dev/null || true

# Windows (Git Bash / MSYS2 / Cygwin): chmod is a no-op on NTFS, so also set an
# explicit NTFS ACL via icacls.exe — remove inherited ACEs and grant full
# control to the current user only. WSL targeting a /mnt/c path is a known gap
# (neither branch below matches). Native cmd/PowerShell can't run this script
# at all (bash shebang), so they're out of scope.
case "$(uname -s 2>/dev/null)" in
  CYGWIN*|MINGW*|MSYS*)
    if command -v icacls.exe >/dev/null 2>&1; then
      _WIN_SETTINGS="$SETTINGS"
      command -v cygpath >/dev/null 2>&1 && _WIN_SETTINGS=$(cygpath -w "$SETTINGS" 2>/dev/null || echo "$SETTINGS")
      icacls.exe "$_WIN_SETTINGS" /inheritance:r /grant:r "$(whoami):F" >/dev/null 2>&1 || true
    fi
    ;;
esac

echo "  MCP server configured in $SETTINGS (permissions restricted)"

# 4. Create state directory
mkdir -p "$HOME/.linear-sdlc/projects"
echo "  State directory created at ~/.linear-sdlc/"

# 5. Register skills (create symlinks)
echo ""
echo "Registering skills..."
mkdir -p "$SKILL_INSTALL_DIR"

# Symlink the root linear-sdlc directory
ln -snf "$SCRIPT_DIR" "$SKILL_INSTALL_DIR/linear-sdlc"
echo "  linked: linear-sdlc (root)"

# Symlink each skill subdirectory that contains a SKILL.md
for skill_dir in "$SCRIPT_DIR"/*/; do
  skill_name=$(basename "$skill_dir")
  if [ -f "$skill_dir/SKILL.md" ]; then
    ln -snf "$skill_dir" "$SKILL_INSTALL_DIR/$skill_name"
    echo "  linked: $skill_name"
  fi
done

# 6. Print success
echo ""
echo "========================================"
echo "  linear-sdlc installed successfully"
echo "========================================"
echo ""
echo "Available skills:"
echo "  /brainstorm      — Plan new features, write specs"
echo "  /create-tickets  — Create Linear issues from specs"
echo "  /next            — Propose next ticket to work on"
echo "  /implement       — Full implementation lifecycle"
echo "  /debug           — Systematic bug investigation"
echo "  /checkpoint      — Save/resume session state"
echo "  /health          — Code quality dashboard"
echo ""
echo "Linear MCP server configured. Restart Claude Code to activate."
echo ""
